---
interface Props {
  href: string
  class?: string
  [key: string]: unknown
}

const { href, class: className, ...rest } = Astro.props
const isExternal = href.startsWith('http')
---

{
  isExternal ? (
    <a href={href} target="_blank" rel="noopener noreferrer" class={className} {...rest}>
      <slot />
    </a>
  ) : (
    <a href={href} class={className} {...rest}>
      <slot />
    </a>
  )
}
