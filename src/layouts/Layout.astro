---
import { ClientRouter } from 'astro:transitions'

import Footer from '@/components/layout/Footer.astro'
import Navbar from '@/components/layout/Navbar.astro'
import { config } from '@/config'
import { getSettingsView } from '@/lib/content'

import '@/globals.css'

import '@fontsource-variable/onest'

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
  noindex?: boolean
}

const SITE = config.site.url
const settings = await getSettingsView()

const {
  title,
  description = settings.defaultSeo?.metaDescription,
  canonical = '/',
  ogImage = settings.defaultSeo?.ogImage,
  noindex = false,
} = Astro.props

const fullTitle = title
  ? `${title} | ${settings.companyName}`
  : settings.defaultSeo?.metaTitle || settings.companyName
const canonicalURL = new URL(canonical, SITE)
const ogImageURL = ogImage ? new URL(ogImage, SITE) : null
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Add your favicon files to /public/icons and wire them here. */}
    <link rel="manifest" href="/manifest.webmanifest" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={settings.companyName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <ClientRouter />
  </head>
  <body class="min-h-screen w-full bg-background overflow-x-hidden">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { initSmoothScroll } from '@/lib/smooth-scroll'
      import { gsap } from 'gsap'
      import { ScrollTrigger } from 'gsap/ScrollTrigger'

      function initLayoutAll() {
        initSmoothScroll()

        const currentPath = window.location.pathname
        const prevPath = sessionStorage.getItem('currentPath')
        if (prevPath && prevPath !== currentPath) {
          sessionStorage.setItem('prevPath', prevPath)
        }
        sessionStorage.setItem('currentPath', currentPath)

        if (window.vtActive) {
          window.scrollTo(0, 0)
          if (window.lenis) {
            window.lenis.scrollTo(0, { immediate: true })
          }
        }
      }

      initLayoutAll()
      document.addEventListener('astro:page-load', initLayoutAll)

      document.addEventListener('astro:before-swap', () => {
        ScrollTrigger.killAll()
        if (window.lenis) {
          window.lenis.destroy()
          window.lenis = undefined
        }
        if (window.lenisTicker) {
          gsap.ticker.remove(window.lenisTicker)
          window.lenisTicker = undefined
        }
      })

      document.addEventListener('astro:before-preparation', (e) => {
        const ev = e as any
        const fromPath = ev.from.pathname
        const toPath = ev.to.pathname
        const isBackFromDetailToProjects =
          ev.direction === 'back' &&
          fromPath.includes('/projects/') &&
          (toPath === '/projects' || toPath === '/projects/')

        if (isBackFromDetailToProjects) {
          const mainImg = document.querySelector<HTMLElement>('.pd-main-image')
          if (mainImg) {
            mainImg.style.setProperty('view-transition-name', 'none')
          }
        }
      })

      document.addEventListener(
        'click',
        (e) => {
          const target = e.target
          if (target instanceof HTMLElement) {
            const anchor = target.closest('a')
            if (!anchor) return
            const href = anchor.getAttribute('href')
            if (!href) return

            try {
              const destUrl = new URL(href, window.location.href)
              const normalize = (p: string) => p.replace(/\/$/, '') || '/'

              if (
                destUrl.origin === window.location.origin &&
                normalize(destUrl.pathname) === '/projects' &&
                normalize(window.location.pathname) === '/projects'
              ) {
                e.preventDefault()
                e.stopPropagation()
                const cat = destUrl.searchParams.get('category') || 'All'
                window.dispatchEvent(
                  new CustomEvent('projects-filter', { detail: { category: cat } })
                )
                if (window.lenis) {
                  window.lenis.scrollTo(0)
                } else {
                  window.scrollTo({ top: 0, behavior: 'smooth' })
                }
                return
              }

              if (
                destUrl.origin === window.location.origin &&
                normalize(destUrl.pathname) === normalize(window.location.pathname) &&
                destUrl.search === window.location.search
              ) {
                e.preventDefault()
                e.stopPropagation()
                if (destUrl.hash) {
                  const id = decodeURIComponent(destUrl.hash.slice(1))
                  const el = document.getElementById(id)
                  if (el) {
                    const headerOffset = 100
                    const y = el.getBoundingClientRect().top + window.scrollY - headerOffset
                    if (window.lenis) {
                      window.lenis.scrollTo(y)
                    } else {
                      window.scrollTo({ top: y, behavior: 'smooth' })
                    }
                    history.replaceState(null, '', destUrl.hash)
                  }
                } else {
                  if (window.lenis) {
                    window.lenis.scrollTo(0)
                  } else {
                    window.scrollTo({ top: 0, behavior: 'smooth' })
                  }
                }
              }
            } catch (err) {}
          }
        },
        { capture: true }
      )

      document.addEventListener('click', (e) => {
        const target = e.target
        if (target instanceof HTMLElement) {
          const anchor = target.closest('a')
          if (!anchor) return
          const href = anchor.getAttribute('href')
          if (!href) return

          if (anchor.hasAttribute('data-back-button')) {
            const prevPath = sessionStorage.getItem('prevPath')
            if (prevPath) {
              try {
                const destUrl = new URL(href, window.location.origin)
                const normalize = (p: string) => p.replace(/\/$/, '') || '/'
                if (normalize(destUrl.pathname) === normalize(prevPath)) {
                  e.preventDefault()
                  history.back()
                  return
                }
              } catch (err) {}
            }
          }

          if (
            href.includes('/projects/') ||
            href.includes('/services/') ||
            href.includes('/blog/')
          ) {
            window.vtActive = true
          }
        }
      })
    </script>
  </body>
</html>
