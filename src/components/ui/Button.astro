---
import { cn } from '@/lib/utils'

interface Props {
  variant?: 'primary' | 'outline' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  class?: string
  [key: string]: unknown
}

const variants = {
  primary: 'text-white bg-neutral-900 hover:bg-neutral-800 border border-neutral-900',
  outline: 'text-neutral-900 bg-transparent hover:bg-neutral-100 border border-neutral-300',
  ghost: 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100',
}

const sizes = {
  sm: 'h-9 px-4 py-2 text-sm',
  md: 'h-11 px-5 py-3 text-base',
  lg: 'h-12 px-6 py-3.5 text-lg',
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props

const classes = cn(
  'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium transition-all outline-none cursor-pointer',
  variants[variant],
  sizes[size],
  className
)
---

{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={classes} {...rest}>
      <slot />
    </button>
  )
}
