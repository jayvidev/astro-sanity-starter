---
interface Props {
  text: string
  wordClass?: string
  class?: string
  tag?: 'h1' | 'h2' | 'h3'
  separator?: 'space' | 'nbsp'
  breakAfter?: number
  breakClass?: string
}

const {
  text,
  wordClass = 'reveal-word',
  class: className,
  tag: Tag = 'h2',
  separator = 'space',
  breakAfter,
  breakClass = 'hidden md:block',
} = Astro.props

const escapeHtml = (value: string) =>
  value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')

const words = text.split(' ')

const html = words
  .map((word, i) => {
    const isLast = i === words.length - 1
    const inner = `<span class="${wordClass} inline-block" style="transform: translateY(105%)">${escapeHtml(word)}</span>`
    const insideSep = separator === 'nbsp' && !isLast ? '<span>&nbsp;</span>' : ''
    const box = `<span class="inline-block overflow-hidden align-bottom pb-1 -mb-1">${inner}${insideSep}</span>`
    let after = ''
    if (separator === 'space' && !isLast) after += ' '
    if (breakAfter === i) after += `<br class="${breakClass}" />`
    return box + after
  })
  .join('')
---

<Tag class={className} set:html={html} />
