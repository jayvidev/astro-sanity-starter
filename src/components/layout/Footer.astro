---
import CustomArrowUpRightIcon from '@/components/icons/CustomArrowUpRightIcon.astro'
import CustomFacebookIcon from '@/components/icons/CustomFacebookIcon.astro'
import CustomInstagramIcon from '@/components/icons/CustomInstagramIcon.astro'
import CustomPinterestIcon from '@/components/icons/CustomPinterestIcon.astro'
import { getSettingsView } from '@/lib/content'

const {
  footerCol1,
  footerCol2,
  socialLinks,
  footerTopCards,
  companyPhone,
  companyEmail,
  companyAddress,
  companyName,
} = await getSettingsView()

const iconMap: Record<string, any> = {
  Instagram: CustomInstagramIcon,
  Facebook: CustomFacebookIcon,
  Pinterest: CustomPinterestIcon,
}

const mappedSocialLinks = socialLinks.map((s) => ({
  ...s,
  label: s.network,
  icon: iconMap[s.network],
}))

const topCards = footerTopCards.map((card, idx) => ({
  ...card,
  containerClasses:
    idx === 0
      ? 'bg-cream rounded-t-xl md:rounded-none md:rounded-l-xl'
      : 'bg-transparent border border-charcoal rounded-b-xl md:rounded-none md:rounded-r-xl',
  textClasses: idx === 0 ? 'text-neutral-dark' : 'text-white',
}))

const contactItems = [
  { label: companyPhone, href: `tel:+1${companyPhone.replace(/\D/g, '')}` },
  { label: companyEmail, href: `mailto:${companyEmail}` },
  { label: companyAddress, href: null },
]

const year = new Date().getFullYear()
---

<footer id="site-footer" class="relative z-20 w-full flex flex-col bg-primary overflow-hidden">
  {/* Top Content Section */}
  <div
    class="relative flex flex-col items-center justify-center px-4 lg:px-6 pt-[clamp(5rem,8vw,6rem)] pb-[clamp(2rem,3vw,2rem)] z-10"
  >
    <div class="max-w-315 w-full mx-auto relative z-10 flex flex-col">
      {/* Top Cards */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 mb-[clamp(5rem,8vw,7rem)]">
        {
          topCards.map((card) => (
            <a
              href={card.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`footer-card opacity-0 ${card.containerClasses} p-[clamp(1rem,2.5vw,1.5rem)] flex flex-row items-center justify-between group transition-colors`}
            >
              <h2 class={`${card.textClasses} text-[clamp(1.875rem,3vw,2rem)] font-semibold`}>
                {card.title}
              </h2>
              <div class={`flex items-center gap-2 font-medium ${card.textClasses}`}>
                <span>{card.actionText}</span>
                <CustomArrowUpRightIcon
                  class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  aria-hidden="true"
                />
              </div>
            </a>
          ))
        }
      </div>

      {/* Links Section */}
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-y-[clamp(2.5rem,6vw,2rem)] gap-x-8 w-full mb-0 lg:mb-[clamp(2rem,5vw,5rem)]"
      >
        {
          [footerCol1, footerCol2].map((col) => (
            <div class="footer-col opacity-0 flex flex-col gap-4 text-white">
              {col.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-white/80 transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </div>
          ))
        }

        {/* Contact Info Column */}
        <div class="footer-col opacity-0 flex flex-col gap-4 text-white">
          {
            contactItems.map((item) =>
              item.href ? (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-white/80 transition-colors break-all"
                >
                  {item.label}
                </a>
              ) : (
                <p class="wrap-break-word">{item.label}</p>
              )
            )
          }
        </div>

        {/* Socials Column */}
        <div class="footer-col opacity-0 flex flex-col gap-4 text-white items-start md:items-end">
          {
            mappedSocialLinks.map((social) => {
              const Icon = social.icon
              return (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 group hover:text-white/80 transition-colors"
                >
                  <span>{social.label}</span>
                  <Icon class="w-4 h-4" aria-hidden="true" />
                </a>
              )
            })
          }
        </div>
      </div>
    </div>
  </div>

  {/* Bottom Black Section */}
  <div
    class="footer-bottom bg-neutral-dark/85 py-8 px-4 lg:px-6 relative z-10 border-t border-charcoal backdrop-blur-md text-cream"
  >
    <div
      class="max-w-325 w-full mx-auto flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <div class="overflow-hidden">
        <p class="footer-bottom-text opacity-0 text-sm md:text-base">
          ©{year}
          {companyName}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  function initFooter() {
    const container = document.getElementById('site-footer')
    if (!container || container.hasAttribute('data-initialized')) return
    container.setAttribute('data-initialized', 'true')

    const ctx = gsap.context(() => {
      gsap.set('.footer-card', { transformPerspective: 1000, transformOrigin: 'center bottom' })

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: container,
          start: 'top 80%',
        },
      })

      tl.fromTo(
        '.footer-card',
        { y: 80, rotationX: -15, opacity: 0, scale: 0.95 },
        {
          y: 0,
          rotationX: 0,
          opacity: 1,
          scale: 1,
          duration: 0.8,
          stagger: 0.1,
          ease: 'expo.out',
        }
      )
        .fromTo(
          '.footer-col',
          { y: 40, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: 'power4.out' },
          '<0.15'
        )
        .fromTo(
          '.footer-bottom-text',
          { y: 20, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: 'back.out(1.2)' },
          '<0.15'
        )
    }, container)

    void ctx
  }

  initFooter()
  document.addEventListener('astro:page-load', initFooter)
</script>
