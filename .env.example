PUBLIC_SITE_URL=YOUR_SITE_URL

PUBLIC_SANITY_STUDIO_PROJECT_ID=YOUR_SANITY_PROJECT_ID
PUBLIC_SANITY_STUDIO_DATASET=production

VERCEL_REVALIDATE_TOKEN=YOUR_TOKEN
SANITY_REVALIDATE_SECRET=YOUR_SECRET

# Optional: origin used for revalidation requests (defaults to PUBLIC_SITE_URL).
# Set to a non-proxied (DNS-only) host pointing at the deploy to bypass a
# proxy/CDN that would block the call — lets you keep e.g. Cloudflare Bot Fight
# Mode on. Omit if no proxy is used.
REVALIDATE_ORIGIN=YOUR_REVALIDATE_ORIGIN
