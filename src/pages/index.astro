---
/**
 * Starter welcome page. Standalone — does NOT query Sanity, so the project boots
 * with an empty .env. Replace this with your real home once a Sanity project is
 * connected — compose your own components and read content via get*View().
 */
import '@/globals.css'

import '@fontsource-variable/onest'

const REPO = 'https://github.com/jayvidev/astro-sanity-starter'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Astro + Sanity Starter</title>
    <meta
      name="description"
      content="Statically-rendered, CMS-driven site starter — Astro + Sanity."
    />
  </head>
  <body class="min-h-screen bg-white font-onest text-neutral-900 antialiased">
    <main
      class="relative flex min-h-screen flex-col items-center justify-center gap-12 overflow-x-hidden px-6 py-20 sm:px-20"
    >
      <div class="flex flex-nowrap items-center justify-center gap-8 sm:gap-12">
        <svg
          class="size-16 text-neutral-900 sm:size-20"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 85 107"
        >
          <path
            fill="currentColor"
            d="M27.59 91.137c-4.834-4.42-6.246-13.704-4.232-20.43 3.492 4.241 8.33 5.584 13.342 6.343 7.737 1.17 15.336.732 22.523-2.804.822-.405 1.582-.943 2.48-1.489.675 1.957.85 3.932.615 5.943-.573 4.896-3.01 8.678-6.885 11.545-1.55 1.147-3.19 2.172-4.79 3.253-4.917 3.323-6.247 7.22-4.4 12.888.044.139.084.277.183.614-2.51-1.124-4.344-2.76-5.742-4.911-1.475-2.27-2.177-4.78-2.214-7.498-.019-1.322-.019-2.656-.197-3.96-.434-3.178-1.926-4.601-4.737-4.683-2.884-.084-5.166 1.699-5.771 4.507-.046.216-.113.429-.18.68z"
          ></path>
          <path
            fill="currentColor"
            d="M0 69.587s14.314-6.973 28.668-6.973L39.49 29.12c.405-1.62 1.588-2.72 2.924-2.72s2.518 1.1 2.924 2.72L56.16 62.614c17 0 28.668 6.973 28.668 6.973S60.514 3.352 60.467 3.219C59.769 1.261 58.591 0 57.003 0H27.827c-1.588 0-2.718 1.261-3.464 3.22C24.311 3.35 0 69.586 0 69.586"
          ></path>
        </svg>

        <span class="text-3xl font-bold text-neutral-300">+</span>

        <svg
          class="size-16 sm:size-20"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 192 192"
        >
          <path
            fill="#F03E2F"
            d="m160.077 112.697-5.212-9.068-25.206 15.352 27.996-35.644 4.233-2.484-1.047-1.573 1.923-2.457-8.835-7.353-4.043 5.153-81.62 47.752 30.177-36.29 56.208-30.81-5.34-10.322-30.615 16.775 15.075-18.118-8.637-7.61-33.928 40.797-33.698 18.48 25.799-34.106 16.166-8.414-5.134-10.438L47.24 66.836l12.844-16.995-8.972-7.186L24 78.538l.42.336 5.066 10.314 30.057-15.653-27.396 36.21 4.49 3.597 2.67 5.162 31.646-17.35-34.848 41.911 8.637 7.609 1.734-2.086 84.067-49.343-27.911 35.547.456.38-.043.027 5.786 10.066 37.123-22.616-14.295 23.067L141.24 152 164 115.278l-3.923-2.581Z"
          ></path>
        </svg>
      </div>

      <div class="mx-auto max-w-xl space-y-4 text-center">
        <h1 class="text-2xl font-bold">Welcome to your Astro + Sanity starter!</h1>
        <p class="text-sm text-neutral-500 sm:text-base">
          A statically-rendered, CMS-driven site template. Connect a Sanity project (see the
          README), then start building by editing
          <code class="rounded bg-neutral-100 px-1 py-0.5 font-semibold">src/pages/index.astro</code
          >.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={REPO}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          GitHub
        </a>
        <a
          href={`${REPO}#readme`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-neutral-300 px-5 py-2.5 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-100"
        >
          Readme
        </a>
      </div>
    </main>
  </body>
</html>
